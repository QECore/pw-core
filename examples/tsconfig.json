{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node20",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@tests/*": ["src/tests/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": [
    "**/*.ts"
  ]
}
